             <string notr="true">/* Estilo do Cabeçalho */
QHeaderView::section {
    background-color: rgb(170, 0, 0);
    color: white;
    padding: 4px;
    font-weight: bold;
    border: 1px solid black; /* Remove a borda padrão grossa */ 
	font: 700 12pt &quot;Montserrat&quot;;
}

/* Estilo do Corpo da Tabela */
QTableWidget {
    gridline-color: #e0e0e0; /* Cor da linha que separa as células (cinza claro) */
    background-color: white;
    alternate-background-color: #f9f9f9; /* Cor para linhas alternadas, se ativado */
    selection-background-color: #d5f5e3; /* Cor de destaque ao clicar (verde claro) */
    selection-color: #27ae60;
    border: 1px solid #dcdcdc;
    border-radius: 4px;
}</string>
