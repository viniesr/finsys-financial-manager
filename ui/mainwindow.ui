             <item>
              <widget class="QComboBox" name="comboBox">
               <property name="styleSheet">
                <string notr="true">/* 1. Caixa Principal - Ajustada para bater com os QLineEdit */
QComboBox {
    border: 1px solid #a9a9a9;
    border-radius: 0px; /* Mantive 0px como você deixou */
    padding: 1px 4px;
    font-family: &quot;Montserrat&quot;;
    font-size: 12pt;
    color: #2c3e50;
    background-color: white;
    min-height: 20px; /* Aumentei um pouco para não cortar o texto 12pt */
}
/* Ajuste da área da seta */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px; 
    border-left: 1px solid #d1d1d1; /* Linha de separação fina */
    background-color: #f9f9f9; 
}

/* O desenho da seta - Versão Fina */
QComboBox::down-arrow {
    image: none; 
    border-left: 3px solid transparent;   /* Largura da base do triângulo */
    border-right: 3px solid transparent;  /* Largura da base do triângulo */
    border-top: 5px solid #555555;        /* Altura e cor da seta */
    margin-top: 2px;                      /* Centraliza verticalmente */
}

/* 4. Lista Suspensa */
QAbstractItemView {
    border: 1px solid #d1d1d1;
    selection-background-color: #e63946; 
    background-color: white;
    outline: none;
    padding: 5px;
}

/* 5. Scrollbar Vertical (Sua barra fininha personalizada) */
QScrollBar:vertical {
    border: none;
    background: #f1f1f1;
    width: 8px; 
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #bcbcbc;
    min-height: 20px;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: #e63946; 
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}</string>
               </property>
